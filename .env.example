# ─── AI Wallet — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Replit, set these in the Secrets tab instead.

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
# Required for real AI cost tracking (ai_cost_logs table).
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@db.[your-project-ref].supabase.co:5432/postgres

# ── Server ────────────────────────────────────────────────────────────────────
# API server port. Must be 8080 locally to match the Vite proxy (target: http://localhost:8080).
# On Replit this is set automatically via the artifact localPort config.
PORT=8080

# ── Replit Auth (OIDC) ────────────────────────────────────────────────────────
# Set automatically by Replit.
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc

# ── AI Provider API Keys ──────────────────────────────────────────────────────
# The AI agent chat uses Gemini. The cost estimator Optimize button also uses Gemini.
# Anthropic and OpenAI keys are optional (only needed if you route tasks to those providers).
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
