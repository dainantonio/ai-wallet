# ─── AI Wallet — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Replit, set these in the Secrets tab instead.

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
# Required for real AI cost tracking (ai_cost_logs table).
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@db.[your-project-ref].supabase.co:5432/postgres

# ── Server ────────────────────────────────────────────────────────────────────
# Set automatically by Replit; override locally if needed.
PORT=3000

# ── Replit Auth (OIDC) ────────────────────────────────────────────────────────
# Set automatically by Replit.
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
