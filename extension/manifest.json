{
  "manifest_version": 3,
  "name": "AI Wallet — Cost Tracker",
  "version": "1.0.0",
  "description": "Track your AI spending in real time",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [{
    "matches": [
      "https://chat.openai.com/*",
      "https://chatgpt.com/*", 
      "https://claude.ai/*",
      "https://gemini.google.com/*"
    ],
    "js": ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
