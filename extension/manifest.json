{
  "manifest_version": 3,
  "name": "AI Wallet — Cost Autopilot",
  "version": "1.0.0",
  "description": "Real-time AI cost awareness. See estimated costs before you submit prompts on ChatGPT and Claude.",

  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://claude.ai/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Wallet",
    "default_icon": {
      "16":  "icons/icon.svg",
      "32":  "icons/icon.svg",
      "48":  "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },

  "icons": {
    "16":  "icons/icon.svg",
    "48":  "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
